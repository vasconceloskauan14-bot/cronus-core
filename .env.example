# ============================================================
# ULTIMATE CRONUS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── Claude / Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ──────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=seu_secret_aqui

# ── Slack ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID=T...

# ── Banco de Dados ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cronus

# ── Busca Web ───────────────────────────────────────────────
BRAVE_API_KEY=BSA...

# ── Google ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ── Notificações ────────────────────────────────────────────
REPORT_EMAIL=seu@email.com

# ── Configurações do Sistema ────────────────────────────────
CRONUS_ENV=production
CRONUS_LOG_LEVEL=INFO
CRONUS_MAX_PARALLEL_AGENTS=6

# IA com memoria no Obsidian
OPENAI_API_KEY=sk-proj-...
CRONUS_PROVIDER=openai
OBSIDIAN_AI_PROVIDER=openai
OBSIDIAN_AI_MODEL=gpt-4o-mini
OBSIDIAN_AI_PORT=8787
OBSIDIAN_AI_VAULT=obsidian-ai-vault
OBSIDIAN_CALENDAR_SOURCE=
OBSIDIAN_CALENDAR_WINDOW_DAYS=1
OBSIDIAN_CALENDAR_STATE=state/obsidian_calendar_state.json
OBSIDIAN_RADAR_CONFIG=config/obsidian_radar.json
OBSIDIAN_RADAR_STATE=state/obsidian_radar_state.json
OBSIDIAN_RADAR_TEMPERATURE=0.3
